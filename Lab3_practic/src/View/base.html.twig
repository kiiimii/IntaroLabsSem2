<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Моя библиотека{% endblock %}</title>
    <style>
        body { font-family: sans-serif; line-height: 1.6; max-width: 900px; margin: 0 auto; padding: 20px; }
        header { border-bottom: 2px solid #333; margin-bottom: 20px; padding-bottom: 10px; }
        .book-card { border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; display: flex; gap: 20px; border-radius: 8px; }
        .book-cover { width: 100px; height: 150px; object-fit: cover; background: #f4f4f4; }
        .btn { padding: 8px 15px; text-decoration: none; border-radius: 4px; display: inline-block; }
        .btn-add { background: #28a745; color: white; }
        .btn-login { background: #007bff; color: white; }
    </style>
</head>
<body>

<header>
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <a href="/" style="text-decoration: none; color: inherit;"><h1>📚 Library MVC</h1></a>
        
        <nav>
            {% if isAuth %}
                <span>Вы: <strong>{{ user }}</strong></span> | 
                <a href="/logout">Выйти</a>
            {% else %}
                <a href="/login" class="btn btn-login">Войти</a>
            {% endif %}
        </nav>
    </div>
</header>

<main>
    {% block body %}{% endblock %}
</main>

<footer>
    <p style="text-align: center; color: #888; margin-top: 50px;">&copy; 2026 Личная библиотека</p>
</footer>

</body>
</html>