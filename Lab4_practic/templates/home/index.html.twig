{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <h1 class="mb-4 text-center text-secondary">{{ title }}</h1>
    
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form id="geocode-form" class="row g-3">
                <div class="col-md-10">
                    <input type="text" id="address" class="form-control form-control-lg" placeholder="Введите адрес (например: Москва, Льва Толстого 16)" required>
                </div>
                <div class="col-md-2">
                    <button type="submit" id="submit-btn" class="btn btn-primary btn-lg w-100">Найти</button>
                </div>
            </form>
        </div>
    </div>

    <div id="result-container" class="d-none">
        <div id="box-success" class="alert alert-success shadow-sm d-none">
            <h5 class="alert-heading mb-3">📍 Данные успешно найдены:</h5>
            <ul class="mb-0">
                <li class="mb-2"><strong>Полный адрес:</strong> <span id="res-address"></span></li>
                <li class="mb-2"><strong>Координаты (Широта, Долгота):</strong> <span id="res-coords"></span></li>
                <li><strong>Ближайшее метро:</strong> <span id="res-metro"></span></li>
            </ul>
        </div>

        <div id="box-error" class="alert alert-danger shadow-sm d-none">
            <h5 class="alert-heading">⚠️ Произошла ошибка</h5>
            <p id="error-text" class="mb-0"></p>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        document.getElementById('geocode-form').addEventListener('submit', async (e) => {
            e.preventDefault();

            const addressInput = document.getElementById('address');
            const btn = document.getElementById('submit-btn');
            const container = document.getElementById('result-container');
            const successBox = document.getElementById('box-success');
            const errorBox = document.getElementById('box-error');

            const addressValue = addressInput.value.trim();
            if (!addressValue) return;

            // Индикация загрузки
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            container.classList.add('d-none');
            successBox.classList.add('d-none');
            errorBox.classList.add('d-none');

            try {
                const response = await fetch('/api/geocode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ address: addressValue })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || `Ошибка сервера: ${response.status}`);
                }

                // Заполняем готовые элементы данными
                document.getElementById('res-address').textContent = data.address;
                document.getElementById('res-coords').textContent = data.coordinates;
                document.getElementById('res-metro').textContent = data.metro;

                successBox.classList.remove('d-none');
            } catch (error) {
                document.getElementById('error-text').textContent = error.message;
                errorBox.classList.remove('d-none');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Найти';
                container.classList.remove('d-none');
            }
        });
    </script>
{% endblock %}